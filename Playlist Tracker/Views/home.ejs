<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>

    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <div class="navbar">

        <h1>Playlist Tracker</h1>

        <div class="nav-links">

            <a href="/"class="active">Home</a>

            <a href="/playlist" >Playlist</a>

            <a href="/favourite">Favourite</a>

            <a href="/create">Create</a>
        </div>

    </div>

    <hr>

    <h2>Welcome to Playlist Tracker 🎵</h2>

    <p>
        Create playlists, listen to your favourite songs,
        and automatically add playlists to favourites after
        listening 3 times.
    </p>

    <h2>Suggested Songs</h2>

    <% if (playlists.length === 0) { %>

        <p>No playlists created yet.</p>

    <% } else { %>

        <% playlists.forEach(playlist => { %>

            <div class="song-card">

                <h3><%= playlist.name %></h3>

                <p><%= playlist.artist %></p>

                <p>Played <%= playlist.playCount %> times</p>

                <% if (playlist.favourite) { %>
                    <p>❤️ Favourite Playlist</p>
                <% } %>

                <div class="song-buttons">

                    <form action="/listen/<%= playlist.id %>" method="POST">
                        <button type="submit">Listen</button>
                    </form>

                    <form action="/favourite/<%= playlist.id %>" method="POST">
                        <button type="submit">
                            <%= playlist.favourite ? 'Remove Favourite' : 'Favourite' %>
                        </button>
                    </form>

                </div>

            </div>

        <% }) %>

    <% } %>

</body>
</html>